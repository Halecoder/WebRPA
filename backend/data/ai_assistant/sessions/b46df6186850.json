        {
          "id": "call_1bcca851aa8f47b1bc42f92f",
          "name": "build_workflow",
          "arguments": {
            "name": "逐行读取txt并打印",
            "steps": [
              {
                "type": "input_prompt",
                "label": "选择txt文件",
                "config": {
                  "prompt_type": "file",
                  "file_filter": ".txt",
                  "result_variable": "file_path"
                }
              },
              {
                "type": "read_text_file",
                "label": "读取文件内容",
                "config": {
                  "file_path": "{{file_path}}",
                  "result_variable": "file_content"
                }
              },
              {
                "type": "string_split",
                "label": "按换行分割",
                "config": {
                  "input_string": "{{file_content}}",
                  "separator": "\n",
                  "result_variable": "lines"
                }
              },
              {
                "type": "foreach",
                "label": "遍历每一行",
                "config": {
                  "list": "{{lines}}",
                  "item_variable": "line"
                }
              },
              {
                "type": "print_log",
                "label": "打印当前行",
                "config": {
